<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="huawei" value="https://repo.huaweicloud.com/repository/nuget/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="huawei">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <config>
    <add key="dependencyVersion" value="Highest" />
    <add key="globalPackagesFolder" value="..\.nuget\packages" />
    <add key="http_proxy" value="" />
    <add key="https_proxy" value="" />
  </config>
  <fallbackPackageFolders>
    <add key="GlobalPackages" value="%USERPROFILE%\.nuget\packages" />
  </fallbackPackageFolders>
</configuration>
