<Window x:Class="DTE10T_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DTE10T_WPF"
        Title="基恩士20站 - 温控器1 - 台达 DTE10T 监控配置"
        Width="1280" Height="900"
        MinWidth="1000" MinHeight="700"
        FontFamily="Microsoft YaHei" FontSize="12">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#1B5E20" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚙ 台达 DTE10T 温度控制器" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" | 基恩士20站.温控器1" Foreground="#A5D6A7" FontSize="13" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="站号:" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="txtStationCode" Text="1" Width="40" VerticalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Text="COM:" Foreground="White" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="cmbComPort" Width="70" SelectedIndex="0" VerticalAlignment="Center">
                        <ComboBoxItem>COM1</ComboBoxItem>
                        <ComboBoxItem>COM2</ComboBoxItem>
                        <ComboBoxItem>COM3</ComboBoxItem>
                        <ComboBoxItem>COM4</ComboBoxItem>
                        <ComboBoxItem>COM5</ComboBoxItem>
                        <ComboBoxItem>COM6</ComboBoxItem>
                        <ComboBoxItem>COM7</ComboBoxItem>
                        <ComboBoxItem>COM8</ComboBoxItem>
                        <ComboBoxItem>COM9</ComboBoxItem>
                        <ComboBoxItem>COM10</ComboBoxItem>
                        <ComboBoxItem>COM11</ComboBoxItem>
                        <ComboBoxItem>COM12</ComboBoxItem>
                        <ComboBoxItem>COM13</ComboBoxItem>
                        <ComboBoxItem>COM14</ComboBoxItem>
                        <ComboBoxItem>COM15</ComboBoxItem>
                        <ComboBoxItem>COM16</ComboBoxItem>
                        <ComboBoxItem>COM17</ComboBoxItem>
                        <ComboBoxItem>COM18</ComboBoxItem>
                        <ComboBoxItem>COM19</ComboBoxItem>
                        <ComboBoxItem>COM20</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="波特率:" Foreground="White" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="cmbBaudRate" Width="90" SelectedIndex="2" VerticalAlignment="Center">
                        <ComboBoxItem Tag="2400">2400</ComboBoxItem>
                        <ComboBoxItem Tag="4800">4800</ComboBoxItem>
                        <ComboBoxItem Tag="9600">9600</ComboBoxItem>
                        <ComboBoxItem Tag="19200">19200</ComboBoxItem>
                        <ComboBoxItem Tag="38400">38400</ComboBoxItem>
                        <ComboBoxItem Tag="57600">57600</ComboBoxItem>
                        <ComboBoxItem Tag="115200">115200</ComboBoxItem>
                    </ComboBox>
                    <Button x:Name="btnConnect" Content="连接" Width="70" Margin="12,0,0,0" Click="BtnConnect_Click" Background="#4CAF50"/>
                    <Button x:Name="btnDisconnect" Content="断开" Width="70" Margin="6,0,0,0" Click="BtnDisconnect_Click" IsEnabled="False" Background="#F44336"/>
                    <Button x:Name="btnRefresh" Content="刷新全部" Width="80" Margin="12,0,0,0" Click="BtnRefresh_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 状态指示灯栏 -->
        <Border Grid.Row="1" Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="0,0,0,1" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="ledPWR" Width="14" Height="14" Fill="Gray" Margin="0,0,4,0" ToolTip="电源"/>
                <TextBlock Text="PWR" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,16,0"/>
                <Ellipse x:Name="ledRUN" Width="14" Height="14" Fill="Gray" Margin="0,0,4,0" ToolTip="运行中"/>
                <TextBlock Text="RUN" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,16,0"/>
                <Ellipse x:Name="ledCOM" Width="14" Height="14" Fill="Gray" Margin="0,0,4,0" ToolTip="通讯中"/>
                <TextBlock Text="COM" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,16,0"/>
                <Ellipse x:Name="ledERR" Width="14" Height="14" Fill="Gray" Margin="0,0,4,0" ToolTip="错误"/>
                <TextBlock Text="ERR" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,32,0"/>
                <TextBlock x:Name="txtStatus" Text="未连接" VerticalAlignment="Center" Foreground="Gray" FontWeight="Bold"/>
                <TextBlock x:Name="txtLastUpdate" Text="" VerticalAlignment="Center" Foreground="Gray" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 主内容区 TabControl -->
        <TabControl Grid.Row="2" x:Name="mainTab" Margin="4" FontFamily="Microsoft YaHei">

            <!-- Tab1: 实时温度监控 -->
            <TabItem Header="🌡 实时温度">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- 通道选择 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                        <TextBlock Text="显示通道:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                        <CheckBox x:Name="chkCH1" Content="CH1" IsChecked="True" Margin="4,0"/>
                        <CheckBox x:Name="chkCH2" Content="CH2" IsChecked="True" Margin="8,0"/>
                        <CheckBox x:Name="chkCH3" Content="CH3" IsChecked="True" Margin="8,0"/>
                        <CheckBox x:Name="chkCH4" Content="CH4" IsChecked="True" Margin="8,0"/>
                        <CheckBox x:Name="chkCH5" Content="CH5" IsChecked="False" Margin="8,0"/>
                        <CheckBox x:Name="chkCH6" Content="CH6" IsChecked="False" Margin="8,0"/>
                        <CheckBox x:Name="chkCH7" Content="CH7" IsChecked="False" Margin="8,0"/>
                        <CheckBox x:Name="chkCH8" Content="CH8" IsChecked="False" Margin="8,0"/>
                        <Button x:Name="btnSelAll" Content="全选" Width="50" Margin="12,0,0,0" Click="BtnSelAll_Click"/>
                        <Button x:Name="btnSelNone" Content="清空" Width="50" Margin="4,0,0,0" Click="BtnSelNone_Click"/>
                    </StackPanel>
                    <!-- 温度显示卡片 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icTempCards">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="8" Margin="6" Padding="16,12"
                                            Background="{Binding BgColor}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Channel}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Row="1" Text="{Binding PV, StringFormat='PV: {0:F1} ℃'}" FontSize="22" FontWeight="Bold"
                                                       Foreground="#1B5E20" HorizontalAlignment="Center" Margin="0,4,0,2"/>
                                            <TextBlock Grid.Row="2" Text="{Binding SV, StringFormat='SV: {0:F1} ℃'}" FontSize="13"
                                                       Foreground="#1565C0" HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Row="3" Text="{Binding Status}" FontSize="11" Foreground="Gray"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Tab2: PV/SV 设定 -->
            <TabItem Header="📊 PV/SV 设定">
                <DataGrid x:Name="dgPVSV" AutoGenerateColumns="False" CanUserAddRows="False"
                          AlternatingRowBackground="{StaticResource RowEvenBrush}"
                          RowBackground="{StaticResource RowOddBrush}"
                          GridLinesVisibility="All" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="PV 当前值 (℃)" Binding="{Binding PV, StringFormat=F1}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="SV 设定值 (℃)" Binding="{Binding SV, StringFormat=F1}" Width="120" IsReadOnly="False"/>
                        <DataGridTextColumn Header="输入类型" Binding="{Binding InputType}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="量程上限 (℃)" Binding="{Binding RangeHigh, StringFormat=F1}" Width="110" IsReadOnly="False"/>
                        <DataGridTextColumn Header="量程下限 (℃)" Binding="{Binding RangeLow, StringFormat=F1}" Width="110" IsReadOnly="False"/>
                        <DataGridCheckBoxColumn Header="通道使能" Binding="{Binding IsEnabled}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Tab3: PID 参数 -->
            <TabItem Header="🔧 PID 参数">
                <DataGrid x:Name="dgPID" AutoGenerateColumns="False" CanUserAddRows="False"
                          AlternatingRowBackground="{StaticResource RowEvenBrush}"
                          RowBackground="{StaticResource RowOddBrush}"
                          GridLinesVisibility="All" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="控制方式" Binding="{Binding ControlMode}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="Pb 比例带" Binding="{Binding Pb, StringFormat=F1}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="Ti 积分 (s)" Binding="{Binding Ti, StringFormat=F0}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="Td 微分 (s)" Binding="{Binding Td, StringFormat=F0}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="积分量 (%)" Binding="{Binding Integral, StringFormat=F1}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="输出1量 (%)" Binding="{Binding Out1, StringFormat=F1}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="输出2量 (%)" Binding="{Binding Out2, StringFormat=F1}" Width="100" IsReadOnly="False"/>
                        <DataGridCheckBoxColumn Header="AT自整定" Binding="{Binding ATEnabled}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Tab4: 警报设定 -->
            <TabItem Header="🔔 警报设定">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,4">
                        <TextBlock Text="警报类型:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbAlarmType" Width="180" SelectedIndex="0">
                            <ComboBoxItem>警报一 (Alarm 1)</ComboBoxItem>
                            <ComboBoxItem>警报二 (Alarm 2)</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="dgAlarm" AutoGenerateColumns="False" CanUserAddRows="False"
                              AlternatingRowBackground="{StaticResource RowEvenBrush}"
                              RowBackground="{StaticResource RowOddBrush}"
                              GridLinesVisibility="All" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="警报模式" Binding="{Binding AlarmMode}" Width="140" IsReadOnly="False"/>
                            <DataGridTextColumn Header="上限值" Binding="{Binding AlarmHigh, StringFormat=F1}" Width="100" IsReadOnly="False"/>
                            <DataGridTextColumn Header="下限值" Binding="{Binding AlarmLow, StringFormat=F1}" Width="100" IsReadOnly="False"/>
                            <DataGridTextColumn Header="延迟 (s)" Binding="{Binding AlarmDelay, StringFormat=F0}" Width="80" IsReadOnly="False"/>
                            <DataGridCheckBoxColumn Header="警报使能" Binding="{Binding AlarmEnabled}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab5: 输出配置 -->
            <TabItem Header="⚡ 输出配置">
                <DataGrid x:Name="dgOutput" AutoGenerateColumns="False" CanUserAddRows="False"
                          AlternatingRowBackground="{StaticResource RowEvenBrush}"
                          RowBackground="{StaticResource RowOddBrush}"
                          GridLinesVisibility="All" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="OUT1 功能" Binding="{Binding Out1Function}" Width="130" IsReadOnly="False"/>
                        <DataGridTextColumn Header="OUT2 功能" Binding="{Binding Out2Function}" Width="130" IsReadOnly="False"/>
                        <DataGridTextColumn Header="输出上限 (%)" Binding="{Binding OutMax, StringFormat=F0}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="输出下限 (%)" Binding="{Binding OutMin, StringFormat=F0}" Width="100" IsReadOnly="False"/>
                        <DataGridTextColumn Header="控制周期 (s)" Binding="{Binding ControlCycle, StringFormat=F0}" Width="100" IsReadOnly="False"/>
                        <DataGridCheckBoxColumn Header="输出反向" Binding="{Binding OutputReverse}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Tab6: 高级功能 -->
            <TabItem Header="📐 高级功能">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- 斜率控制 -->
                        <GroupBox Header="斜率控制 (Slope)" Margin="4">
                            <StackPanel Margin="8">
                                <TextBlock Text="温度设定值按设定斜率上升，单位 0.1℃/min" Foreground="Gray" Margin="0,0,0,8"/>
                                <DataGrid x:Name="dgSlope" AutoGenerateColumns="False" CanUserAddRows="False" Height="200"
                                          AlternatingRowBackground="{StaticResource RowEvenBrush}"
                                          RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="SV 目标 (℃)" Binding="{Binding SV, StringFormat=F1}" Width="100"/>
                                        <DataGridTextColumn Header="斜率 (0.1℃/min)" Binding="{Binding Slope, StringFormat=F0}" Width="130"/>
                                        <DataGridCheckBoxColumn Header="启用斜率" Binding="{Binding SlopeEnabled}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </GroupBox>
                        <!-- 输入补偿 -->
                        <GroupBox Header="输入误差调整" Margin="4">
                            <DataGrid x:Name="dgInputAdj" AutoGenerateColumns="False" CanUserAddRows="False" Height="200"
                                      AlternatingRowBackground="{StaticResource RowEvenBrush}"
                                      RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="补偿值 (0.1℃)" Binding="{Binding Offset, StringFormat=F0}" Width="120"/>
                                    <DataGridTextColumn Header="增益 (‰)" Binding="{Binding Gain, StringFormat=F0}" Width="100"/>
                                    <DataGridTextColumn Header="滤波次数" Binding="{Binding FilterCount, StringFormat=F0}" Width="80"/>
                                    <DataGridTextColumn Header="滤波范围" Binding="{Binding FilterRange, StringFormat=F1}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <!-- CT 电流检知 -->
                        <GroupBox Header="CT 电流检知" Margin="4">
                            <DataGrid x:Name="dgCT" AutoGenerateColumns="False" CanUserAddRows="False" Height="160"
                                      AlternatingRowBackground="{StaticResource RowEvenBrush}"
                                      RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="CT 保持值" Binding="{Binding CTStatic, StringFormat=F0}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="CT 动态值" Binding="{Binding CTDynamic, StringFormat=F0}" Width="100" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="CT 调整值" Binding="{Binding CTAdjust, StringFormat=F0}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <!-- EVENT 输入 -->
                        <GroupBox Header="EVENT 事件输入" Margin="4">
                            <DataGrid x:Name="dgEvent" AutoGenerateColumns="False" CanUserAddRows="False" Height="160"
                                      AlternatingRowBackground="{StaticResource RowEvenBrush}"
                                      RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="EVENT 功能" Binding="{Binding EventFunction}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <!-- 热流道控制 -->
                        <GroupBox Header="热流道控制 (Hot Runner)" Margin="4">
                            <DataGrid x:Name="dgHotRunner" AutoGenerateColumns="False" CanUserAddRows="False" Height="200"
                                      AlternatingRowBackground="{StaticResource RowEvenBrush}"
                                      RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="通道" Binding="{Binding Channel}" Width="60" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="界限温度 (0.1℃)" Binding="{Binding LimitTemp, StringFormat=F0}" Width="130"/>
                                    <DataGridTextColumn Header="固定输出量 (0.1%)" Binding="{Binding FixedOutput, StringFormat=F0}" Width="130"/>
                                    <DataGridTextColumn Header="定时 (min)" Binding="{Binding SoakTime, StringFormat=F0}" Width="80"/>
                                    <DataGridTextColumn Header="SV 目标 (℃)" Binding="{Binding SV, StringFormat=F1}" Width="100"/>
                                    <DataGridTextColumn Header="斜率 (0.1℃/min)" Binding="{Binding Slope, StringFormat=F0}" Width="130"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab7: 通讯参数 -->
            <TabItem Header="🔌 通讯参数">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Modbus RTU 通讯参数设定（写入后需重启生效）" Foreground="Gray" Margin="8,4"/>
                    <DataGrid Grid.Row="1" x:Name="dgComm" AutoGenerateColumns="False" CanUserAddRows="False"
                              AlternatingRowBackground="{StaticResource RowEvenBrush}"
                              RowBackground="{StaticResource RowOddBrush}"
                              GridLinesVisibility="All" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="参数" Binding="{Binding ParamName}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="当前值" Binding="{Binding ParamValue}" Width="160" IsReadOnly="False"/>
                            <DataGridTextColumn Header="说明" Binding="{Binding ParamDesc}" Width="400" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab8: 可程控 -->
            <TabItem Header="📅 可程控">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="样式规划" FontWeight="Bold" Margin="8,4"/>
                    <DataGrid Grid.Row="1" x:Name="dgProgramPattern" AutoGenerateColumns="False" CanUserAddRows="False" Height="220"
                              AlternatingRowBackground="{StaticResource RowEvenBrush}"
                              RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="样式" Binding="{Binding Pattern}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="最大步骤数" Binding="{Binding MaxSteps, StringFormat=F0}" Width="100"/>
                            <DataGridTextColumn Header="循环次数" Binding="{Binding LoopCount, StringFormat=F0}" Width="100"/>
                            <DataGridTextColumn Header="下一样式" Binding="{Binding NextPattern, StringFormat=F0}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="2" Text="步骤设定 (目标温度 &amp; 运行时间)" FontWeight="Bold" Margin="8,4"/>
                    <DataGrid Grid.Row="3" x:Name="dgProgramSteps" AutoGenerateColumns="False" CanUserAddRows="False"
                              AlternatingRowBackground="{StaticResource RowEvenBrush}"
                              RowBackground="{StaticResource RowOddBrush}" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="样式" Binding="{Binding Pattern}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="步骤" Binding="{Binding Step}" Width="60" IsReadOnly="True"/>
                            <DataGridTextColumn Header="目标温度 (℃)" Binding="{Binding TargetTemp, StringFormat=F1}" Width="120"/>
                            <DataGridTextColumn Header="运行时间 (min)" Binding="{Binding RunTime, StringFormat=F0}" Width="120"/>
                            <DataGridTextColumn Header="时间单位" Binding="{Binding TimeUnit}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="txtConnStatus" Text="● 未连接" Foreground="Gray"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="txtDeviceInfo" Text="| 基恩士20站.温控器1 | SlaveID: 1 | COM1 | 9600bps"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtReadCount" Text="读取次数: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
