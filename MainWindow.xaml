<Window
    x:Class="DTE10T_WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:DTE10T_WPF"
    xmlns:oxy="clr-namespace:OxyPlot.SkiaSharp.Wpf;assembly=OxyPlot.SkiaSharp.Wpf"
    Title="温控器1 - 台达 DTE10T 监控配置"
    Width="1280"
    Height="900"
    MinWidth="1000"
    MinHeight="700"
    Closing="Window_Closing"
    FontFamily="Microsoft YaHei"
    FontSize="14">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="321*" />
            <ColumnDefinition Width="959*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  顶部工具栏  -->
        <Border
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Margin="0,0,0,0"
            Padding="12,8"
            Background="#1B5E20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="⚙ 台达 DTE10T 温度控制器" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="#A5D6A7"
                        Text=" | 温控器1" />
                </StackPanel>
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="站号:" />
                    <TextBox
                        x:Name="txtStationCode"
                        Width="40"
                        VerticalAlignment="Center"
                        Text="1"
                        TextAlignment="Center" />
                    <TextBlock
                        Margin="12,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="COM:" />
                    <ComboBox
                        x:Name="cmbComPort"
                        Width="70"
                        VerticalAlignment="Center"
                        SelectedIndex="0">
                        <ComboBoxItem>COM1</ComboBoxItem>
                        <ComboBoxItem>COM2</ComboBoxItem>
                        <ComboBoxItem>COM3</ComboBoxItem>
                        <ComboBoxItem>COM4</ComboBoxItem>
                        <ComboBoxItem>COM5</ComboBoxItem>
                        <ComboBoxItem>COM6</ComboBoxItem>
                        <ComboBoxItem>COM7</ComboBoxItem>
                        <ComboBoxItem>COM8</ComboBoxItem>
                        <ComboBoxItem>COM9</ComboBoxItem>
                        <ComboBoxItem>COM10</ComboBoxItem>
                        <ComboBoxItem>COM11</ComboBoxItem>
                        <ComboBoxItem>COM12</ComboBoxItem>
                        <ComboBoxItem>COM13</ComboBoxItem>
                        <ComboBoxItem>COM14</ComboBoxItem>
                        <ComboBoxItem>COM15</ComboBoxItem>
                        <ComboBoxItem>COM16</ComboBoxItem>
                        <ComboBoxItem>COM17</ComboBoxItem>
                        <ComboBoxItem>COM18</ComboBoxItem>
                        <ComboBoxItem>COM19</ComboBoxItem>
                        <ComboBoxItem>COM20</ComboBoxItem>
                    </ComboBox>
                    <TextBlock
                        Margin="12,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="协议:" />
                    <ComboBox
                        x:Name="cmbProtocol"
                        Width="80"
                        VerticalAlignment="Center"
                        SelectedIndex="1">
                        <ComboBoxItem Tag="ASCII">ASCII</ComboBoxItem>
                        <ComboBoxItem Tag="RTU">RTU</ComboBoxItem>
                    </ComboBox>
                    <TextBlock
                        Margin="12,0,4,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Text="波特率:" />
                    <ComboBox
                        x:Name="cmbBaudRate"
                        Width="90"
                        VerticalAlignment="Center"
                        SelectedIndex="2">
                        <ComboBoxItem Tag="2400">2400</ComboBoxItem>
                        <ComboBoxItem Tag="4800">4800</ComboBoxItem>
                        <ComboBoxItem Tag="9600">9600</ComboBoxItem>
                        <ComboBoxItem Tag="19200">19200</ComboBoxItem>
                        <ComboBoxItem Tag="38400">38400</ComboBoxItem>
                        <ComboBoxItem Tag="57600">57600</ComboBoxItem>
                        <ComboBoxItem Tag="115200">115200</ComboBoxItem>
                    </ComboBox>
                    <Button
                        x:Name="btnConnect"
                        Width="70"
                        Margin="12,0,0,0"
                        Background="#4CAF50"
                        Click="BtnConnect_Click"
                        Content="连接" />
                    <Button
                        x:Name="btnDisconnect"
                        Width="70"
                        Margin="6,0,0,0"
                        Background="#F44336"
                        Click="BtnDisconnect_Click"
                        Content="断开"
                        IsEnabled="False" />
                    <Button
                        x:Name="btnRefresh"
                        Width="80"
                        Margin="12,0,0,0"
                        Click="BtnRefresh_Click"
                        Content="刷新全部"
                        IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  状态指示灯栏  -->
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,0,0,0"
            Padding="12,0"
            Background="#E8F5E9"
            BorderBrush="#A5D6A7"
            BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Ellipse
                    x:Name="ledPWR"
                    Width="14"
                    Height="14"
                    Margin="0,0,4,0"
                    Fill="Gray"
                    ToolTip="电源" />
                <TextBlock
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="PWR" />
                <Ellipse
                    x:Name="ledRUN"
                    Width="14"
                    Height="14"
                    Margin="0,0,4,0"
                    Fill="Gray"
                    ToolTip="运行中" />
                <TextBlock
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="RUN" />
                <Ellipse
                    x:Name="ledCOM"
                    Width="14"
                    Height="14"
                    Margin="0,0,4,0"
                    Fill="Gray"
                    ToolTip="通讯中" />
                <TextBlock
                    Margin="0,0,16,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="COM" />
                <Ellipse
                    x:Name="ledERR"
                    Width="14"
                    Height="14"
                    Margin="0,0,4,0"
                    Fill="Gray"
                    ToolTip="错误" />
                <TextBlock
                    Margin="0,0,32,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="ERR" />
                <TextBlock
                    x:Name="txtStatus"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Foreground="Gray"
                    Text="未连接" />
                <TextBlock
                    x:Name="txtLastUpdate"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="Gray"
                    Text="" />
            </StackPanel>
        </Border>

        <!--  主内容区 TabControl  -->
        <TabControl
            x:Name="mainTab"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="4,4,4,4"
            FontFamily="Microsoft YaHei">

            <!--  Tab1: 实时温度监控  -->
            <TabItem Header="🌡 实时温度">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <!--  通道选择  -->
                    <StackPanel
                        Grid.Row="0"
                        Margin="8,8,8,4"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Text="显示通道:" />
                        <CheckBox
                            x:Name="chkCH1"
                            Margin="4,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH1"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH2"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH2"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH3"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH3"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH4"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH4"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH5"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH5"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH6"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH6"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH7"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH7"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <CheckBox
                            x:Name="chkCH8"
                            Margin="8,0"
                            Checked="ChkChannel_CheckedChanged"
                            Content="CH8"
                            IsChecked="True"
                            Unchecked="ChkChannel_CheckedChanged" />
                        <Button
                            x:Name="btnSelAll"
                            Width="50"
                            Margin="12,0,0,0"
                            Click="BtnSelAll_Click"
                            Content="全选" />
                        <Button
                            x:Name="btnSelNone"
                            Width="50"
                            Margin="4,0,0,0"
                            Click="BtnSelNone_Click"
                            Content="清空" />
                        <StackPanel
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="显示曲线:" />
                            <CheckBox
                                x:Name="chkShowChart"
                                Checked="ChkShowChart_CheckedChanged"
                                Content="实时曲线"
                                IsChecked="True"
                                Unchecked="ChkShowChart_CheckedChanged" />
                            <CheckBox
                                x:Name="chkShowOut1"
                                Margin="8,0,0,0"
                                Checked="ChkShowOut1_CheckedChanged"
                                Content="输出1"
                                IsChecked="True"
                                Unchecked="ChkShowOut1_CheckedChanged" />
                            <CheckBox
                                x:Name="chkShowOut2"
                                Margin="8,0,0,0"
                                Checked="ChkShowOut2_CheckedChanged"
                                Content="输出2"
                                IsChecked="True"
                                Unchecked="ChkShowOut2_CheckedChanged" />
                        </StackPanel>
                    </StackPanel>
                    <!--  内容区域  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        <!--  左侧温度卡片  -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="icTempCards">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="6"
                                            Padding="16,12"
                                            Background="{Binding BgColor}"
                                            BorderBrush="#BDBDBD"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock
                                                    Grid.Row="0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="30"
                                                    FontWeight="Bold"
                                                    Text="{Binding Channel}" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Margin="0,4,0,2"
                                                    HorizontalAlignment="Center"
                                                    FontSize="20"
                                                    FontWeight="Bold"
                                                    Foreground="#1B5E20"
                                                    Text="{Binding PV, StringFormat='PV: {0:F1} ℃'}" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    HorizontalAlignment="Center"
                                                    FontSize="20"
                                                    Foreground="#1565C0"
                                                    Text="{Binding SV, StringFormat='SV: {0:F1} ℃'}" />
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Margin="0,4,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="15"
                                                    Foreground="#E65100"
                                                    Text="{Binding RateOfChange, StringFormat='加热速率: {0:F1} ℃/min'}" />
                                                <TextBlock
                                                    Grid.Row="4"
                                                    Margin="0,4,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="15"
                                                    Foreground="Gray"
                                                    Text="{Binding Status}" />
                                                <TextBlock
                                                    Grid.Row="5"
                                                    Margin="0,4,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="15"
                                                    Foreground="#4527A0"
                                                    Text="{Binding Mean, StringFormat='μ: {0:F1} ℃'}" />
                                                <TextBlock
                                                    Grid.Row="6"
                                                    Margin="0,2,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="15"
                                                    Foreground="#5D4037"
                                                    Text="{Binding StdDev, StringFormat='σ: {0:F2}'}" />
                                                <TextBlock
                                                    Grid.Row="7"
                                                    Margin="0,2,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="15"
                                                    Foreground="#00695C"
                                                    Text="{Binding ZScore, StringFormat='Z: {0:F2}'}" />
                                                <TextBlock
                                                    Grid.Row="8"
                                                    Margin="0,2,0,0"
                                                    HorizontalAlignment="Center"
                                                    FontSize="15"
                                                    Foreground="#BF360C"
                                                    Text="{Binding Probability, StringFormat='P: {0:F4}'}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <!--  右侧实时曲线图表  -->
                        <Border
                            Grid.Column="1"
                            Margin="4"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Visibility="{Binding ShowChartVisibility}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel
                                    Grid.Row="0"
                                    Margin="8,4"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Text="温度范围:" />
                                    <TextBox
                                        x:Name="txtTempLower"
                                        Width="70"
                                        Margin="0,0,4,0"
                                        Padding="2"
                                        TextAlignment="Center"
                                        ToolTip="温度下界" />
                                    <TextBlock
                                        Margin="0,0,4,0"
                                        VerticalAlignment="Center"
                                        Text="~" />
                                    <TextBox
                                        x:Name="txtTempUpper"
                                        Width="70"
                                        Margin="0,0,4,0"
                                        Padding="2"
                                        TextAlignment="Center"
                                        ToolTip="温度上界" />
                                    <Button
                                        x:Name="btnApplyTempRange"
                                        Width="60"
                                        Margin="0,0,12,0"
                                        Click="BtnApplyTempRange_Click"
                                        Content="应用" />
                                    <Button
                                        x:Name="btnClearChart"
                                        Width="80"
                                        Margin="4"
                                        Click="BtnClearChart_Click"
                                        Content="清空曲线" />
                                    <Button
                                        x:Name="btnPauseChart"
                                        Width="60"
                                        Margin="4"
                                        Click="BtnPauseChart_Click"
                                        Content="暂停" />
                                    <Button
                                        x:Name="btnSaveImage"
                                        Width="100"
                                        Margin="4"
                                        Click="BtnSaveImage_Click"
                                        Content="保存图像" />
                                    <Button
                                        x:Name="btnStartRecord"
                                        Width="80"
                                        Margin="4"
                                        Background="#4CAF50"
                                        Click="BtnStartRecord_Click"
                                        Content="开始记录"
                                        Foreground="White" />
                                    <Button
                                        x:Name="btnStopRecord"
                                        Width="80"
                                        Margin="4"
                                        Background="#F44336"
                                        Click="BtnStopRecord_Click"
                                        Content="结束记录"
                                        Foreground="White"
                                        IsEnabled="False" />
                                </StackPanel>
                                <oxy:PlotView
                                    x:Name="pvTemperature"
                                    Grid.Row="1"
                                    Margin="4"
                                    Model="{Binding TemperaturePlotModel}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!--  Tab2: PV/SV 设定  -->
            <TabItem Header="📊 PV/SV 设定">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="8,4"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Text="设置全部:" />
                        <TextBox
                            x:Name="txtSetAllSV"
                            Width="100"
                            Margin="0,0,4,0"
                            Padding="2"
                            TextAlignment="Center"
                            ToolTip="SV 设定值" />
                        <Button
                            Width="70"
                            Margin="0,0,8,0"
                            Click="BtnSetAllSV_Click"
                            Content="SV全部" />
                        <TextBox
                            x:Name="txtSetAllRangeHigh"
                            Width="90"
                            Margin="0,0,4,0"
                            Padding="2"
                            TextAlignment="Center"
                            ToolTip="量程上限" />
                        <Button
                            Width="70"
                            Margin="0,0,8,0"
                            Click="BtnSetAllRangeHigh_Click"
                            Content="上限全部" />
                        <TextBox
                            x:Name="txtSetAllRangeLow"
                            Width="90"
                            Margin="0,0,4,0"
                            Padding="2"
                            TextAlignment="Center"
                            ToolTip="量程下限" />
                        <Button
                            Width="70"
                            Margin="0,0,8,0"
                            Click="BtnSetAllRangeLow_Click"
                            Content="下限全部" />
                        <CheckBox
                            x:Name="chkSetAllEnabled"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Content="通道使能" />
                        <Button
                            Width="70"
                            Click="BtnSetAllEnabled_Click"
                            Content="使能全部" />
                    </StackPanel>
                    <DataGrid
                        x:Name="dgPVSV"
                        Grid.Row="1"
                        AlternatingRowBackground="{StaticResource RowEvenBrush}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CellEditEnding="DgPVSV_CellEditEnding"
                        GridLinesVisibility="All"
                        HeadersVisibility="Column"
                        RowBackground="{StaticResource RowOddBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="60"
                                Binding="{Binding Channel}"
                                Header="通道"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding PV, StringFormat=F1}"
                                Header="PV 当前值 (℃)"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding SV, StringFormat=F1}"
                                Header="SV 设定值 (℃)"
                                IsReadOnly="False" />
                            <DataGridTextColumn
                                Width="120"
                                Binding="{Binding InputType}"
                                Header="输入类型"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding RangeHigh, StringFormat=F1}"
                                Header="量程上限 (℃)"
                                IsReadOnly="False" />
                            <DataGridTextColumn
                                Width="110"
                                Binding="{Binding RangeLow, StringFormat=F1}"
                                Header="量程下限 (℃)"
                                IsReadOnly="False" />
                            <DataGridCheckBoxColumn
                                Width="80"
                                Binding="{Binding IsEnabled}"
                                Header="通道使能" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!--  Tab3: PID 参数  -->
            <TabItem Header="🔧 PID 参数">
                <DataGrid
                    x:Name="dgPID"
                    AlternatingRowBackground="{StaticResource RowEvenBrush}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CellEditEnding="DgPID_CellEditEnding"
                    GridLinesVisibility="All"
                    HeadersVisibility="Column"
                    RowBackground="{StaticResource RowOddBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding Channel}"
                            Header="通道"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding ControlMode}"
                            Header="控制方式"
                            IsReadOnly="False" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Pb, StringFormat=F1}"
                            Header="Pb 比例带"
                            IsReadOnly="False" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Ti, StringFormat=F0}"
                            Header="Ti 积分 (s)"
                            IsReadOnly="False" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Td, StringFormat=F0}"
                            Header="Td 微分 (s)"
                            IsReadOnly="False" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Integral, StringFormat=F1}"
                            Header="积分量 (%)"
                            IsReadOnly="False" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Out1, StringFormat=F1}"
                            Header="输出1量 (%)"
                            IsReadOnly="False" />
                        <DataGridTextColumn
                            Width="100"
                            Binding="{Binding Out2, StringFormat=F1}"
                            Header="输出2量 (%)"
                            IsReadOnly="False" />
                        <DataGridCheckBoxColumn
                            Width="80"
                            Binding="{Binding ATEnabled}"
                            Header="AT自整定" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!--  Tab4: 警报设定  -->
            <TabItem Header="🔔 警报设定">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel
                        Grid.Row="0"
                        Margin="8,4"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Text="警报类型:" />
                        <ComboBox
                            x:Name="cmbAlarmType"
                            Width="180"
                            SelectedIndex="0">
                            <ComboBoxItem>警报一 (Alarm 1)</ComboBoxItem>
                            <ComboBoxItem>警报二 (Alarm 2)</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <DataGrid
                        x:Name="dgAlarm"
                        Grid.Row="1"
                        AlternatingRowBackground="{StaticResource RowEvenBrush}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        CellEditEnding="DgAlarm_CellEditEnding"
                        GridLinesVisibility="All"
                        HeadersVisibility="Column"
                        RowBackground="{StaticResource RowOddBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="60"
                                Binding="{Binding Channel}"
                                Header="通道"
                                IsReadOnly="True" />
                            <DataGridTextColumn
                                Width="140"
                                Binding="{Binding AlarmMode}"
                                Header="警报模式"
                                IsReadOnly="False" />
